          "refId": "A",
          "format": "table",
          "rawSql": "select u.display_name as artist, count(*) as plays from plays p join songs s on s.id = p.song_id join albums a on a.id = s.album_id join users u on u.id = a.artist_id where p.played_at >= now() - interval '7 days' group by u.display_name order by plays desc limit 5;",
          "dataset": "muzodb",
          "rawQuery": true
